{
  "name": "global-smart-crm",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.cjs",
    "seed": "node server/seed.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "start:prod": "npm run build && node server/index.cjs",
    "electron:dev": "npx electron .",
    "electron:build": "npm run build && electron-builder --win",
    "electron:pack": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.globalsmart.crm",
    "productName": "Global Smart CRM",
    "directories": {
      "buildResources": "electron/resources",
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "!electron/resources/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "Global Smart CRM"
    },
    "forceCodeSigning": false
  }
}
